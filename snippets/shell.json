{
    "bang": {
        "prefix": "bang",
        "body": [
            "#!/usr/bin/env bash"
        ],
        "description": "basic bash header"
    },
    "initiny": {
        "prefix": "initiny",
        "body": [
            "#!/usr/bin/env bash",
            "# Description: ",
            "",
            "set -euo pipefail",
            ""
        ],
        "description": "Ultra-minimal bash script init"
    },
    "init_script": {
        "prefix": "init",
        "body": [
            "#!/usr/bin/env bash",
            "# Author: Bruno Guimarães",
            "# Description:",
            "# Version: 1.0",
            "",
            "set -euo pipefail",
            "IFS=$'\\n\\t'",
            "",
            "# ──────────────────────────────────────────────────────────────────────────────",
            "# Constants / Config",
            "# ──────────────────────────────────────────────────────────────────────────────",
            "",
            "# ──────────────────────────────────────────────────────────────────────────────",
            "# Functions",
            "# ──────────────────────────────────────────────────────────────────────────────",
            "",
            "# ──────────────────────────────────────────────────────────────────────────────",
            "# Main",
            "# ──────────────────────────────────────────────────────────────────────────────",
            "main() {",
            "  ${0}",
            "}",
            "",
            "# ──────────────────────────────────────────────────────────────────────────────",
            "# Entry Point",
            "# ──────────────────────────────────────────────────────────────────────────────",
            "# Only run main if script is executed (not sourced)",
            "[[ \"${BASH_SOURCE[0]}\" == \"\\${0}\" ]] && main \"$@\""
        ],
        "description": "Custom shebang"
    },
    "tempdir": {
        "prefix": "tmpd",
        "body": [
            "TMP_DIR=\"$(mktemp -d)\"",
            "trap 'rm -rf \"\\$TMP_DIR\"' EXIT INT TERM"
        ],
        "description": "Create temp dir and ensure cleanup on exit (POSIX-safe)"
    },
    "confirm_dialog": {
        "prefix": "ifyes",
        "body": [
            "confirm() {",
            "  printf \"%s [y/N]: \" \"\\$1\"",
            "  read -r ans",
            "  case \"\\$ans\" in",
            "    [yY]|[yY][eE][sS]) return 0 ;;",
            "    *) return 1 ;;",
            "  esac",
            "}"
        ],
        "description": "Yes/No confirmation helper (default: No, POSIX-safe)"
    },
    "doc_function": {
        "prefix": "docfun",
        "body": [
            ""
        ],
        "description": "Documentation for the function"
    },
    "new_function": {
        "prefix": "fun",
        "body": [
            "${0}() {",
            "",
            "}"
        ],
        "description": "Documentation for the function"
    },
    "new_section": {
        "prefix": "section",
        "body": [
            "# ──────────────────────────────────────────────────────────────────────────────",
            "# ${0}",
            "# ──────────────────────────────────────────────────────────────────────────────"
        ],
        "description": "Documentation for the function"
    },
    "iffile": {
        "prefix": "iffile",
        "body": [
            "if [[ -f \"$1\" ]]; then",
            "    echo \"File exists: $1\"",
            "else",
            "    echo \"File not found: $1\"",
            "    exit 1",
            "fi"
        ],
        "description": "check if file exist"
    },
    "rfile": {
        "prefix": "rfile",
        "body": [
            "while IFS= read -r line; do",
            "  echo \"$line\"",
            "done < \"$1\""
        ],
        "description": "read file lines"
    },
    "ifdir": {
        "prefix": "ifdir",
        "body": [
            "if [[ -d \"$1\" ]]; then",
            "  echo \"Directory exists: $1\"",
            "else",
            "  echo \"Directory not found: $1\"",
            "  exit 1",
            "fi"
        ],
        "description": "check if folder exist"
    },
    "ifcmd": {
        "prefix": "ifcmd",
        "body": [
            "if command -v \"$1\" >/dev/null 2>&1; then",
            "  echo \"Command available: $1\"",
            "else",
            "  echo \"Command not found: $1\"",
            "  exit 1",
            "fi"
        ],
        "description": "check if command exists in PATH"
    },
    "ifdeps": {
        "prefix": "ifdeps",
        "body": [
            "# Dependency Check",
            "for cmd in $1; do",
            "  command -v \"\\$cmd\" >/dev/null 2>&1 || {",
            "    loge \"Missing dependency: \\$cmd\"",
            "    exit 1",
            "  }",
            "done"
        ],
        "description": "check required command dependencies and exit if any are missing"
    },
    "ifsu": {
        "prefix": "ifsu",
        "body": [
            "if [[ \"$(id -u)\" -ne 0 ]]; then",
            "  echo \"This script must be run as root\"",
            "  exit 1",
            "fi"
        ],
        "description": "Check if is root"
    },
    "rmext": {
        "prefix": "rmext",
        "body": [
            "filename=\"$1\"",
            "basename=\"${filename%.*}\"",
            "echo \"$basename\""
        ],
        "description": "Remove file extension"
    },
    "ifarg": {
        "prefix": "ifarg",
        "body": [
            "ensure_args(){",
            "  if [[ $# -eq 0 ]]; then",
            "    echo \"Usage: $(basename \"$0\") <PROJECT_PATH>\" >&2",
            "    return 1",
            "  fi",
            "}"
        ],
        "description": "check if there's any arguments"
    },
    "forin": {
        "prefix": "forin",
        "body": [
            "for item in \"$@\"; do",
            "  echo \"$item\"",
            "done"
        ],
        "description": "Loop through arguments"
    },
    "read_input": {
        "prefix": "read",
        "body": [
            "read -rp \"Enter value: \" value",
            "echo \"You entered: $value\""
        ],
        "description": "read input on the same line"
    },
    "getopt": {
        "prefix": "getopt",
        "body": [
            "OPTS=$(getopt -o h --long help -- \"$@\");",
            "eval set -- \"$OPTS\"",
            "",
            "while true; do",
            "  case \"$1\" in",
            "    -h|--help)",
            "      echo \"Show help message\"",
            "      exit 0",
            "      ;;",
            "    --)",
            "      shift",
            "      break",
            "      ;;",
            "  esac",
            "done"
        ],
        "description": "Get user parameter option like --help|-h"
    },
    "getopts": {
        "prefix": "getopts",
        "body": [
            "while getopts \":hv\" opt; do",
            "  case $opt in",
            "    h)",
            "      echo \"Show help\"",
            "      exit 0",
            "      ;;",
            "    v)",
            "      echo \"Verbose mode enabled\"",
            "      ;;",
            "    \\?)",
            "      echo \"Invalid option: -$OPTARG\" >&2",
            "      exit 1",
            "      ;;",
            "  esac",
            "done"
        ],
        "description": "Cycle and process all user parameters"
    },
    "usage": {
        "prefix": "usage",
        "body": [
            "usage() {",
            "  cat <<EOF",
            "Usage: $(basename \"$0\") [options]",
            "",
            "Options:",
            "  -h, --help     Show this help message",
            "",
            "EOF",
            "  exit 0",
            "}"
        ],
        "description": "Function skeleton for script usage"
    },
    "script_dir": {
        "prefix": "sdir",
        "body": [
            "readonly SCRIPT_DIR=\"$( cd \"$( dirname \"${BASH_SOURCE[0]}\" )\" && pwd )\""
        ],
        "description": "Find script path"
    },
    "script_dir2": {
        "prefix": "sdir2",
        "body": [
            "readonly SCRIPT_DIR=\"$( cd \"$( dirname \"${BASH_SOURCE[0]}\" )/..\" && pwd )\""
        ],
        "description": "Find script path"
    },
    "script_dir_link": {
        "prefix": "sdirlink",
        "body": [
            "readonly SCRIPT_DIR=\"$(cd \"$(dirname \"$(readlink -f \"${BASH_SOURCE[0]}\")\")\" && pwd)\""
        ],
        "description": "Find script path"
    },
    "script_dir_link2": {
        "prefix": "sdirlink2",
        "body": [
            "readonly SCRIPT_DIR=\"$(cd \"$(dirname \"$(readlink -f \"${BASH_SOURCE[0]}\")\")/..\" && pwd)\""
        ],
        "description": "Find script path"
    },
    "timestamp": {
        "prefix": "timestamp",
        "body": [
            "${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}T${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}+0300 | ${CURRENT_SECONDS_UNIX} ${1}"
        ],
        "description": "timestamp in ISO8601 and unix"
    },
    "variable": {
        "prefix": "var",
        "body": [
            "\"\\${${1}}\" $0"
        ],
        "description": "Variable with proper format"
    },
    "const": {
        "prefix": "const",
        "body": [
            "readonly ${1:NAME}=\"${2:value}\""
        ],
        "description": "Readonly constant"
    },
    "ifgrep": {
        "prefix": "ifgrep",
        "body": [
            "if ! grep -q '${1:CONTENT}' \"${2:FILE}\"; then",
            "  ${0}",
            "fi"
        ],
        "description": "Check if content does NOT exist in file"
    },
    "log_all": {
        "prefix": "logall",
        "body": [
            "logs() { printf '\\033[0;32m[BRLK SUCCESS]\\033[0m - %s\\n' \"\\$1\"; }",
            "loge() { printf '\\033[0;31m[BRLK ERROR]\\033[0m - %s\\n' \"\\$1\"; }",
            "logw() { printf '\\033[1;33m[BRLK WARNING]\\033[0m - %s\\n' \"\\$1\"; }",
            "logi() { printf '\\033[0;34m[BRLK INFO]\\033[0m - %s\\n' \"\\$1\"; }",
            "logd() { printf '\\033[0;35m[BRLK DEBUG]\\033[0m - %s\\n' \"\\$1\"; }",
            "log()  { printf '[BRLK] - %s\\n' \"\\$1\"; }"
        ],
        "description": "Insert all BRLK log helpers (POSIX-safe, printf-based)"
    },
    "log_success": {
        "prefix": "logs",
        "body": [
            "logs() { printf '\\033[0;32m[BRLK SUCCESS]\\033[0m - %s\\n' \"\\$1\"; }"
        ],
        "description": "Log success message (POSIX printf)"
    },
    "log_error": {
        "prefix": "loge",
        "body": [
            "loge() { printf '\\033[0;31m[BRLK ERROR]\\033[0m - %s\\n' \"\\$1\" >&2; }"
        ],
        "description": "Log error message to stderr (POSIX printf)"
    },
    "log_warning": {
        "prefix": "logw",
        "body": [
            "logw() { printf '\\033[1;33m[BRLK WARNING]\\033[0m - %s\\n' \"\\$1\"; }"
        ],
        "description": "Log warning message (POSIX printf)"
    },
    "log_info": {
        "prefix": "logi",
        "body": [
            "logi() { printf '\\033[0;34m[BRLK INFO]\\033[0m - %s\\n' \"\\$1\"; }"
        ],
        "description": "Log info message (POSIX printf)"
    },
    "log_debug": {
        "prefix": "logd",
        "body": [
            "logd() { printf '\\033[0;35m[BRLK DEBUG]\\033[0m - %s\\n' \"\\$1\"; }"
        ],
        "description": "Log debug message (POSIX printf)"
    },
    "log_plain": {
        "prefix": "log",
        "body": [
            "log() { printf '[BRLK] - %s\\n' \"\\$1\"; }"
        ],
        "description": "Plain log message (POSIX printf)"
    }
}
